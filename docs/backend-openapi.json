{
  "components": {
    "schemas": {
      "AuthResponse": {
        "properties": {
          "csrf_token": {
            "title": "Csrf Token",
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          }
        },
        "required": [
          "user",
          "csrf_token"
        ],
        "title": "AuthResponse",
        "type": "object"
      },
      "CheckoutRequest": {
        "properties": {
          "plan_id": {
            "exclusiveMinimum": 0.0,
            "title": "Plan Id",
            "type": "integer"
          }
        },
        "required": [
          "plan_id"
        ],
        "title": "CheckoutRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "MockPaymentCompletionResponse": {
        "properties": {
          "activated_now": {
            "title": "Activated Now",
            "type": "boolean"
          },
          "payment": {
            "$ref": "#/components/schemas/PaymentResponse"
          },
          "subscription": {
            "$ref": "#/components/schemas/SubscriptionResponse"
          }
        },
        "required": [
          "payment",
          "subscription",
          "activated_now"
        ],
        "title": "MockPaymentCompletionResponse",
        "type": "object"
      },
      "PaymentResponse": {
        "properties": {
          "amount": {
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Amount",
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "currency": {
            "title": "Currency",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "paid_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Paid At"
          },
          "payment_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Payment Url"
          },
          "plan_id": {
            "title": "Plan Id",
            "type": "integer"
          },
          "provider": {
            "title": "Provider",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "id",
          "plan_id",
          "provider",
          "amount",
          "currency",
          "status",
          "payment_url",
          "created_at",
          "paid_at"
        ],
        "title": "PaymentResponse",
        "type": "object"
      },
      "PlanResponse": {
        "properties": {
          "currency": {
            "title": "Currency",
            "type": "string"
          },
          "device_limit": {
            "title": "Device Limit",
            "type": "integer"
          },
          "duration_days": {
            "title": "Duration Days",
            "type": "integer"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "price": {
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
            "title": "Price",
            "type": "string"
          },
          "traffic_limit_bytes": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Traffic Limit Bytes"
          }
        },
        "required": [
          "id",
          "name",
          "duration_days",
          "price",
          "currency",
          "traffic_limit_bytes",
          "device_limit"
        ],
        "title": "PlanResponse",
        "type": "object"
      },
      "PublicUser": {
        "properties": {
          "first_name": {
            "title": "First Name",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "language_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Language Code"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "telegram_id": {
            "title": "Telegram Id",
            "type": "integer"
          },
          "username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Username"
          }
        },
        "required": [
          "id",
          "telegram_id",
          "username",
          "first_name",
          "language_code",
          "status"
        ],
        "title": "PublicUser",
        "type": "object"
      },
      "SubscriptionResponse": {
        "properties": {
          "expires_at": {
            "format": "date-time",
            "title": "Expires At",
            "type": "string"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "plan_id": {
            "title": "Plan Id",
            "type": "integer"
          },
          "provisioning_status": {
            "title": "Provisioning Status",
            "type": "string"
          },
          "starts_at": {
            "format": "date-time",
            "title": "Starts At",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "id",
          "plan_id",
          "starts_at",
          "expires_at",
          "status",
          "provisioning_status"
        ],
        "title": "SubscriptionResponse",
        "type": "object"
      },
      "TelegramAuthRequest": {
        "properties": {
          "init_data": {
            "maxLength": 16384,
            "minLength": 1,
            "title": "Init Data",
            "type": "string"
          }
        },
        "required": [
          "init_data"
        ],
        "title": "TelegramAuthRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "AGentVPN API",
    "version": "0.3.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/auth/logout": {
      "post": {
        "operationId": "logout_api_auth_logout_post",
        "responses": {
          "204": {
            "description": "Successful Response"
          }
        },
        "summary": "Logout",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/auth/me": {
      "get": {
        "operationId": "me_api_auth_me_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicUser"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Me",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/auth/telegram": {
      "post": {
        "operationId": "telegram_auth_api_auth_telegram_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TelegramAuthRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Telegram Auth",
        "tags": [
          "auth"
        ]
      }
    },
    "/api/checkout/mock": {
      "post": {
        "operationId": "mock_checkout_api_checkout_mock_post",
        "parameters": [
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "maxLength": 128,
              "minLength": 8,
              "title": "Idempotency-Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckoutRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Mock Checkout",
        "tags": [
          "payments"
        ]
      }
    },
    "/api/payments/{payment_id}": {
      "get": {
        "operationId": "get_payment_api_payments__payment_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "payment_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Payment Id",
              "type": "string"
            }
          }
