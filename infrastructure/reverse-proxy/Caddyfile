{
	admin off
}

{$PUBLIC_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}

	request_body {
		max_size 2MB
	}

	@homepage path /
	handle @homepage {
		root * /srv/agentvpn-public
		rewrite * /index.html
		file_server
	}

	handle {
		reverse_proxy api:8000
	}
}
