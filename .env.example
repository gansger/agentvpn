# Public application
APP_ENV=production
PUBLIC_DOMAIN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
SESSION_SECRET=
CSRF_SECRET=
ADMIN_TELEGRAM_IDS=
CORS_ORIGINS=
SESSION_COOKIE_NAME=agentvpn_session
SESSION_TTL_SECONDS=3600
TELEGRAM_AUTH_MAX_AGE_SECONDS=300
TELEGRAM_REPLAY_TTL_SECONDS=600
COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=none
AUTH_RATE_LIMIT_PER_MINUTE=20

# PostgreSQL and Redis
POSTGRES_DB=agentvpn
POSTGRES_USER=agentvpn
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://agentvpn:change-me@postgres:5432/agentvpn
REDIS_URL=redis://redis:6379/0
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# 3x-ui provisioning
XUI_BASE_URL=
XUI_API_TOKEN=
XUI_USERNAME=
XUI_PASSWORD=
XUI_TWO_FACTOR_CODE=
XUI_HYSTERIA2_INBOUND_ID=
XUI_VLESS_REALITY_INBOUND_ID=
XUI_REQUEST_TIMEOUT_SECONDS=10
XUI_VERIFY_TLS=true
XUI_SAFE_RETRY_ATTEMPTS=3
XUI_CIRCUIT_FAILURE_THRESHOLD=3
XUI_CIRCUIT_RESET_SECONDS=30

# Stage 1 OpenAPI snapshot helper. Override only after inspecting the panel.
XUI_OPENAPI_PATH=/panel/api/openapi.json
XUI_API_TOKEN_HEADER=Authorization
XUI_API_TOKEN_SCHEME=Bearer

# ENOT
ENOT_API_BASE_URL=https://api.enot.io
ENOT_SHOP_ID=
ENOT_SECRET_KEY=
ENOT_WEBHOOK_ADDITIONAL_KEY=
ENOT_SBP_SERVICE_CODE=
ENOT_PAYMENT_EXPIRE_MINUTES=30

# Happ
HAPP_PROVIDER_ID=
HAPP_IOS_URL=
HAPP_ANDROID_URL=
HAPP_WINDOWS_URL=
HAPP_MACOS_URL=
HAPP_LINUX_URL=
